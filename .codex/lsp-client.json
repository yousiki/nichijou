{
  "lsp": {
    "nixd": {
      "command": [
        "nix",
        "--extra-experimental-features",
        "nix-command flakes",
        "run",
        "--inputs-from",
        ".",
        "nixpkgs#nixd",
        "--"
      ],
      "extensions": [".nix"]
    },
    "biome": {
      "command": [
        "nix",
        "--extra-experimental-features",
        "nix-command flakes",
        "run",
        "--inputs-from",
        ".",
        "nixpkgs#biome",
        "--",
        "lsp-proxy"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
        ".json",
        ".jsonc",
        ".vue",
        ".astro",
        ".svelte",
        ".css",
        ".graphql",
        ".gql",
        ".html"
      ]
    },
    "basedpyright": {
      "command": [
        "nix",
        "--extra-experimental-features",
        "nix-command flakes",
        "run",
        "--inputs-from",
        ".",
        "nixpkgs#basedpyright",
        "--",
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [".py", ".pyi"]
    }
  }
}
